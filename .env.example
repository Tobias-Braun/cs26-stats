# Copy to .env and fill in your Supabase project details.
# Without SUPABASE_URL + SUPABASE_KEY the Nuxt app runs in demo/stub mode.

# Nuxt dashboard (anon / public key — read-only access)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-anon-public-key

# get-val.py scraper (service role key — write access, never expose client-side)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
